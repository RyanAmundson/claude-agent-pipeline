{
  "name": "claude-agent-pipeline",
  "version": "0.3.0",
  "description": "A self-orchestrating multi-agent dev pipeline for Claude Code. One orchestrator loop watches a backlog, dispatches specialist agents on demand, and routes work through scan → ticket → implement → review → human-merge. Stack-agnostic; ships an opinionated TypeScript/React preset.",
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "ai",
    "pipeline",
    "orchestration",
    "automation",
    "code-review"
  ],
  "homepage": "https://github.com/RyanAmundson/claude-agent-pipeline",
  "bugs": "https://github.com/RyanAmundson/claude-agent-pipeline/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyanAmundson/claude-agent-pipeline.git"
  },
  "license": "MIT",
  "author": "Ryan Amundson",
  "type": "module",
  "bin": {
    "agent-pipeline": "bin/cli.js",
    "claude-agent-pipeline": "bin/cli.js"
  },
  "exports": {
    "./api": {
      "types": "./api/index.d.ts",
      "import": "./api/index.js"
    }
  },
  "types": "./api/index.d.ts",
  "files": [
    "agents/",
    "rules/",
    "commands/",
    "queue/",
    "skills/",
    "bin/",
    "api/",
    "ui/",
    "runner/",
    "scripts/install-local.sh",
    "manifest.json",
    "plugin.json",
    "config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node bin/cli.js list-agents > /dev/null && node bin/cli.js list-presets > /dev/null && echo 'cli smoke ok'",
    "test:ui": "node --test \"test/ui/**/*.test.js\"",
    "test:unit": "node --test \"test/unit/**/*.test.js\"",
    "test:e2e:smoke": "bash test/e2e/01-lifecycle-smoke.sh",
    "test:e2e": "bash test/e2e/run-all.sh",
    "pack:dry": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=18"
  }
}
